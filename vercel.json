{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css",  "use": "@vercel/static" },
    { "src": "*.js",   "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/manage", "dest": "/manage.html" },
    { "src": "/plan-book", "dest": "/plan-book.html" },
    { "src": "/discover", "dest": "/discover-riyadh.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
